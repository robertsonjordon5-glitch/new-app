<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>JSE Dividend Tracker</title>
    <style>
        :root { --bg: #0B1528; --card: #1E293B; --green: #00E676; --text: #FFFFFF; }
        body { margin: 0; background: var(--bg); color: var(--text); font-family: -apple-system, sans-serif; padding-bottom: 70px; }
        .header { padding: 20px; text-align: center; color: var(--green); font-size: 20px; font-weight: bold; border-bottom: 1px solid var(--card); }
        .container { padding: 15px; }
        .card { background: var(--card); padding: 15px; border-radius: 12px; margin-bottom: 15px; }
        input { width: 100%; padding: 12px; margin: 8px 0; background: #0B1528; color: white; border: 1px solid var(--green); border-radius: 6px; box-sizing: border-box; }
        button { width: 100%; padding: 12px; background: var(--green); color: #000; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; }
        .ad-space { position: fixed; bottom: 0; width: 100%; height: 50px; background: #000; text-align: center; color: #555; line-height: 50px; font-size: 12px; }
        .stat { font-size: 24px; color: var(--green); font-weight: bold; }
    </style>
</head>
<body>
    <div class="header">JSE DIVIDEND TRACKER</div>
    <div class="container">
        <div class="card">
            <div>Projected Annual Income (JMD)</div>
            <div id="annual-income" class="stat">$0.00</div>
        </div>
        <div class="card">
            <input type="text" id="stock-name" placeholder="Stock Ticker (e.g., SVL)">
            <input type="number" id="shares" placeholder="Number of Shares">
            <input type="number" id="dividend" placeholder="Dividend per Share (JMD)">
            <button onclick="calculate()">Add to Portfolio</button>
        </div>
        <div id="portfolio-list"></div>
    </div>
    <div class="ad-space">AdMob Banner Unit</div>

    <script>
        let portfolio = [];
        function calculate() {
            const shares = parseFloat(document.getElementById('shares').value);
            const div = parseFloat(document.getElementById('dividend').value);
            if(shares && div) {
                const total = shares * div;
                portfolio.push({ticker: document.getElementById('stock-name').value, total});
                updateUI();
            }
        }
        function updateUI() {
            let sum = portfolio.reduce((a, b) => a + b.total, 0);
            document.getElementById('annual-income').innerText = '$' + sum.toLocaleString();
            let html = portfolio.map(item => `<div class="card">${item.ticker}: $${item.total.toFixed(2)}</div>`).join('');
            document.getElementById('portfolio-list').innerHTML = html;
        }
    </script>
</body>
</html>
